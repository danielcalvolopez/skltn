# Local Development Setup
# See README.md for full details

# Terminal 1 — Start the obs proxy
lsof -ti:8080 | xargs kill 2>/dev/null
RUST_LOG=debug $HOME/.cargo/bin/cargo run -p skltn-obs -- --port 8080 &

# Terminal 2 — Register MCP server (once per project)
claude mcp add skltn-mcp -- cargo run -p skltn-mcp -- "$(pwd)"

# Terminal 2 — Start Claude through the proxy
ANTHROPIC_BASE_URL=http://localhost:8080 claude

# Dashboard: http://localhost:8080/dashboard
